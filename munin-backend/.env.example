# Server
PORT=4000
CORS_ORIGIN=http://localhost:5173

# SQLite file path (created automatically, gitignored)
DB_PATH=./munin.db

# Groq — powers everything LLM-related in the demo: document/meeting
# knowledge extraction AND real, LLM-grounded "Ask Munin" answers.
# Free tier, no card. Get a key at https://console.groq.com
# If GROQ_API_KEY is not set, Ask Munin automatically falls back to
# keyword matching over the knowledge base (same cited-answer and
# gap-logging behavior, just without generative phrasing), and document/
# meeting uploads will return a clear "extraction unavailable" message
# instead of crashing.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Used only by the recording-upload feature (routes/media.js) for
# speech-to-text on uploaded video/audio files — separate from GROQ_MODEL,
# which is the chat/extraction model above.
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# Fake SSO — no real auth, just a click-through token for the demo login screen
DEMO_SSO_TOKEN=munin-demo-sso-token

# Recall.ai — powers "send Munin to a meeting" (Zoom/Meet/Teams bot).
# Get a key at https://www.recall.ai (free trial available).
RECALL_API_KEY=
# The region your Recall.ai workspace was created in, e.g. us-west-2,
# us-east-1, eu-central-1, ap-northeast-1. Check your Recall dashboard.
RECALL_API_REGION=us-west-2

# Publicly reachable base URL of THIS backend, used so Recall.ai can POST
# real-time transcript events to /api/meetings/webhook. In local dev this
# must be a static ngrok domain (a plain "npx ngrok http 4000" URL changes
# every restart and will break re-joins). Leave blank to still create bots,
# just without real-time transcript delivery.
# Example: PUBLIC_BASE_URL=https://munin-demo.ngrok-free.app
PUBLIC_BASE_URL=

# Langfuse — optional observability/tracing for every Groq call (extraction,
# Ask Munin, transcription): prompts, outputs, latency, token usage, and
# failures, viewable in the Langfuse dashboard. Purely additive — leave
# blank and every LLM call runs exactly as before, just untraced.
# Free account at https://cloud.langfuse.com (or self-host, see their docs).
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
